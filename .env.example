# Shopify App
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app.example.com
SCOPES=read_orders,write_orders,read_customers,write_customers,read_products

# Database
DATABASE_URL=postgresql://nokto:nokto_pass@localhost:5432/nokto_ehf

# Redis
REDIS_URL=redis://localhost:6379

# Encryption key (32 bytes base64, generate with: openssl rand -base64 32)
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_32

# Peppol / EHF Access Point
# Options: mock | storecove
PEPPOL_PROVIDER=mock
STORECOVE_API_URL=https://api.storecove.com/api/v2
STORECOVE_API_KEY=your_storecove_api_key
STORECOVE_SENDER_ID=your_sender_id_from_storecove

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=faktura@yourcompany.no

# Fiken Accounting
FIKEN_CLIENT_ID=your_fiken_client_id
FIKEN_CLIENT_SECRET=your_fiken_client_secret
FIKEN_REDIRECT_URI=https://your-app.example.com/auth/fiken/callback

# App Config
NODE_ENV=development
LOG_LEVEL=info
SESSION_SECRET=change_me_session_secret_min_32_chars

# Billing (NOK)
MONTHLY_PRICE_NOK=1490
USAGE_PRICE_PER_EHF_NOK=6
INCLUDED_EHF_PER_MONTH=50
TRIAL_DAYS=7

# Data Retention (days)
RETENTION_WEBHOOK_LOGS=90
RETENTION_AUDIT_LOGS=180
RETENTION_INVOICES=2555
