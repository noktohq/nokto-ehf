# ============================================================
# NOKTO EHF - Produksjonsmiljø
# ============================================================
# VIKTIG: Kopier denne filen til .env og fyll inn verdiene
# ALDRI commit .env til git!
# ============================================================

# ========================
# SHOPIFY
# ========================
# Finn disse i Partner Dashboard → Apps → Din app → API credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://app.nokto.no
SHOPIFY_API_VERSION=2025-01
SCOPES=read_orders,write_orders,read_customers,write_customers,read_products

# ========================
# RUNTIME
# ========================
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# ========================
# DATABASE
# ========================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# ========================
# REDIS
# ========================
# Format: redis://:PASSWORD@HOST:PORT
REDIS_URL=

# ========================
# KRYPTERING
# ========================
# Generer med: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# VIKTIG: Må være nøyaktig 32 bytes (44 tegn i base64)
ENCRYPTION_KEY=

# ========================
# E-POST (SMTP)
# ========================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=faktura@nokto.no

# ========================
# FIKEN INTEGRASJON
# ========================
# Opprett app på: https://fiken.no/utvikler
FIKEN_CLIENT_ID=
FIKEN_CLIENT_SECRET=
FIKEN_REDIRECT_URI=https://app.nokto.no/auth/fiken/callback

# ========================
# PEPPOL / EHF
# ========================
# Verdier: mock | production
PEPPOL_PROVIDER=production
# Kun for production:
PEPPOL_ACCESS_POINT_URL=
PEPPOL_API_KEY=

# ========================
# BILLING
# ========================
MONTHLY_PRICE_NOK=1490
USAGE_PRICE_PER_EHF_NOK=6
INCLUDED_EHF_PER_MONTH=50
TRIAL_DAYS=7

# ========================
# DATA RETENTION (dager)
# ========================
RETENTION_WEBHOOK_LOGS=90
RETENTION_AUDIT_LOGS=180
RETENTION_INVOICES=2555
