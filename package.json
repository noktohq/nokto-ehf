{
  "type": "module",
  "name": "nokto-ehf-invoicing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "dev:local": "remix vite:dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "setup": "prisma generate && prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "workers": "tsx app/workers/index.ts",
    "start": "remix-serve build/server/index.js"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@remix-run/node": "^2.10.0",
    "@remix-run/react": "^2.10.0",
    "@remix-run/serve": "^2.10.0",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.2.0",
    "@shopify/shopify-app-remix": "^3.2.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.1",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1",
    "isbot": "^5.1.8",
    "nodemailer": "^6.9.14",
    "pdf-lib": "^1.17.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^10.0.0",
    "xmlbuilder2": "^3.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@playwright/test": "^1.45.2",
    "@remix-run/dev": "^2.10.0",
    "@shopify/api-codegen-preset": "^1.1.1",
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "prisma": "5.22.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.0.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.5.0"
}
