{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@shopify/ui-extensions-react/checkout"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
